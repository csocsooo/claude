{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npx --yes *)",
      "Bash(npx gltfjsx:*)",
      "Bash(npx @gltf-transform/cli:*)",
      "Bash(node mcp-servers/*)",
      "Bash(git init)",
      "Bash(git add:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(curl --fail --location *)",
      "Bash(bash skills/3d-builder/scripts/*.sh:*)",
      "Bash(bash ~/.claude/skills/3d-builder/scripts/*.sh:*)",
      "Bash(mkdir -p:*)",
      "Bash(cp -r:*)",
      "Bash(sed -i*:*)",
      "Bash(chmod +x:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(du:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(npm publish:*)",
      "Bash(npx vercel --prod *)"
    ]
  },
  "mcpServers": {
    "three-d-assets": {
      "command": "node",
      "args": ["./mcp-servers/three-d-assets/dist/index.js"],
      "env": {
        "SKETCHFAB_TOKEN": "${SKETCHFAB_TOKEN:-}",
        "MESHY_API_KEY": "${MESHY_API_KEY:-}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ -d skills/3d-builder ] && [ ! -x skills/3d-builder/scripts/scaffold.sh ]; then chmod +x skills/3d-builder/scripts/*.sh; fi; echo \"3d-builder ready. Try: /3d-site <theme>\"'"
          }
        ]
      }
    ]
  }
}
